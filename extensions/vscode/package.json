{
  "name": "kelpmesh",
  "displayName": "kelpmesh",
  "description": "Pure SQL transformation and data modelling — lineage, tests, and run controls",
  "version": "0.1.0",
  "publisher": "kelpmesh",
  "license": "Apache-2.0",
  "icon": "icon.png",
  "repository": { "type": "git", "url": "https://github.com/saikatxtreme/kelpmesh" },
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Programming Languages", "Data Science", "Linters"],
  "keywords": ["sql", "dbt", "data", "analytics", "transformation"],
  "galleryBanner": { "color": "#667eea", "theme": "dark" },
  "activationEvents": [
    "onLanguage:sql",
    "onCommand:kelpmesh.runModel",
    "onCommand:kelpmesh.testModel",
    "onCommand:kelpmesh.previewModel",
    "onCommand:kelpmesh.showLineage"
  ],
  "main": "./src/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "kelpmesh.runModel",
        "title": "KelpMesh: Run Model"
      },
      {
        "command": "kelpmesh.testModel",
        "title": "KelpMesh: Test Model"
      },
      {
        "command": "kelpmesh.previewModel",
        "title": "KelpMesh: Preview 100 Rows"
      },
      {
        "command": "kelpmesh.showLineage",
        "title": "KelpMesh: Show Lineage"
      },
      {
        "command": "kelpmesh.buildProject",
        "title": "KelpMesh: Build Project"
      },
      {
        "command": "kelpmesh.openDocs",
        "title": "KelpMesh: Open Documentation"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "when": "editorLangId == sql",
          "command": "kelpmesh.runModel",
          "group": "kelpmesh@1"
        },
        {
          "when": "editorLangId == sql",
          "command": "kelpmesh.testModel",
          "group": "kelpmesh@2"
        },
        {
          "when": "editorLangId == sql",
          "command": "kelpmesh.previewModel",
          "group": "kelpmesh@3"
        },
        {
          "when": "editorLangId == sql",
          "command": "kelpmesh.showLineage",
          "group": "kelpmesh@4"
        }
      ]
    },
    "languages": [
      {
        "id": "sql",
        "extensions": [".sql"],
        "aliases": ["SQL"]
      }
    ]
  }
}
